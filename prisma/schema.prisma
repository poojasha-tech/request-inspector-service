// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Endpoint{
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  createdAt DateTime @default(now())
  requests   Request[]
}
model Request{
  id         Int      @id @default(autoincrement())
  endpointId  Int //foreign key 
  method     String
  ip        String
  headers    String
  body       String ?
  createdAt  DateTime @default(now())

  endpoint Endpoint @relation(fields: [endpointId], references: [id]) // that is match endpointId in Request with id in Endpoint
}